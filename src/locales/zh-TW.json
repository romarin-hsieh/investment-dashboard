      },
      "adx": {
        "term": "ADX（平均趨向指標）：",
        "desc": "衡量趨勢的強度。讀數高於 25 代表趨勢強勁。"
      },
      "ichimoku": {
        "term": "一目均衡表：",
        "desc": "全方位趨勢系統。價格位於雲帶上方偏多，位於下方偏空。"
      },
      "atr": {
        "term": "ATR（平均真實區間）：",
        "desc": "衡量市場波動度。數值越高代表價格波動越大。"
      },
      "mfi": {
        "term": "MFI（資金流量指標）：",
        "desc": "以成交量加權的 RSI。高於 80 為超買，低於 20 為超賣。"
      },
      "obv": {
        "term": "OBV（能量潮）：",
