{
  "name": "investment-dashboard",
  "services": [
    {
      "name": "web",
      "source": {
        "type": "git"
      },
      "template": "node",
      "env": {
        "NODE_ENV": "production"
      },
      "build": {
        "commands": [
          "npm ci",
          "npm run build"
        ]
      },
      "start": {
        "command": "npm run preview"
      },
      "port": 4173
    }
  ]
}