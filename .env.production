# Production build only. Serve pre-computed data from the separate data repo
# (romarin-hsieh/investment-dashboard-data), same-origin GitHub Pages — see
# Stream 3 data-repo split. Consumed by getDataBaseUrl()/withDataBase() in
# src/utils/baseUrl.js. Local dev does NOT load this file, so it falls back to
# the app BASE_URL and serves data from the local public/data.
VITE_DATA_BASE_URL=https://romarin-hsieh.github.io/investment-dashboard-data/
