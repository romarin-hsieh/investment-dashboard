{
  "name": "investment-dashboard",
  "version": "1.0.0",
  "description": "POC Investment Information Dashboard - A static web application for tracking macro indicators and stock portfolio",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "cross-env ANALYZE=1 vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "update-daily": "python scripts/generate-real-ohlcv-yfinance.py && node scripts/generate-daily-technical-indicators.js && node scripts/generate-daily-snapshot.js && node scripts/generate-quotes-snapshot.js",
    "validate:data": "node scripts/validate-data.js",
    "update:sentiment": "python scripts/update_sentiment.py",
    "fetch:fundamentals": "node scripts/fetch-fundamentals.js"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "lightweight-charts": "^4.1.0",
    "plotly.js-dist-min": "^3.3.1",
    "puppeteer": "^24.34.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "cross-env": "^10.1.0",
    "jsdom": "^24.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.97.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.5",
    "yahoo-finance2": "^3.11.2"
  },
  "build": {
    "timestamp": "2025-12-26T00:00:00.000Z",
    "environment": "production"
  }
}
