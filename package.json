{
  "name": "investment-dashboard",
  "version": "1.0.0",
  "type": "module",
  "description": "POC Investment Information Dashboard - A static web application for tracking macro indicators and stock portfolio",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --port 4173 --host",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.vue --fix",
    "format": "prettier --write .",
    "deploy:github": "npm run build && gh-pages -d dist",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod --dir=dist",
    "precompute": "node scripts/precompute-indicators.js",
    "test-precompute": "node scripts/test-precompute.js",
    "update-metadata": "node scripts/update-metadata.js",
    "update-metadata:force": "node scripts/update-metadata.js --force",
    "update-yfinance": "node scripts/update-yfinance-metadata.js",
    "update-yfinance:force": "node scripts/update-yfinance-metadata.js --force",
    "update-exchanges": "node scripts/update-exchanges.js",
    "cors-proxy": "node local-cors-proxy.js"
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.20.0",
    "fast-check": "^3.15.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
